APP_ENV=local
DATABASE_URL=postgresql+psycopg://muratorium:muratorium@db:5432/muratorium
REDIS_URL=redis://redis:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# OpenAI
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_BATCH_SIZE=25
DIGEST_WINDOW_HOURS=12
DIGEST_TOP_N=10
DIGEST_MIN_SCORE=70
DIGEST_MAX_CANDIDATES=120
FAST_LANE_ENABLED=true
FAST_POLL_SECONDS=120
FAST_MIN_SOURCES=2
FAST_SCORE_THRESHOLD=80
FAST_TITLE_SIMILARITY=85
CLEANUP_ENABLED=true
CLEANUP_HOUR=4
CLEANUP_MINUTE=30
CLEANUP_BATCH_SIZE=5000
CLEANUP_KEEP_PUBLISHED_DAYS=30
CLEANUP_KEEP_UNPUBLISHED_DAYS=7
CLEANUP_KEEP_MESSAGES_DAYS=30

# Publishing policy
URGENT_THRESHOLD=8
CONFIDENCE_THRESHOLD=0.7
URGENT_RATE_LIMIT_PER_HOUR=6
DIGEST_THRESHOLD=6

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/pipeline.log
LOG_ROTATION_DAYS=3
LOG_BACKUP_COUNT=1
